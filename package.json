{
  "name": "sistema-mad",
  "version": "0.1.0",
  "description": "Motor de Debate Multi-Agente para documentación técnica",
  "type": "module",
  "main": "director.js",
  "scripts": {
    "test": "SET NODE_TLS_REJECT_UNAUTHORIZED=0 && node test_briefing.js",
    "start": "SET NODE_TLS_REJECT_UNAUTHORIZED=0 && node director.js",
    "lint:docs": "node tools/mad-linter.cjs ./docs",
    "test:linter": "node tools/test_linter.cjs",
    "index:docs": "node tools/mad-index.cjs ./docs --salida docs/mad-index.json",
    "index:compare": "node tools/mad-index.cjs ./docs --salida docs/mad-index.json --comparar"
  },
  "keywords": ["MAD", "multi-agent", "debate", "LLM", "documentacion"],
  "author": "Claudio (DGSISAN)",
  "license": "MIT",
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^16.4.5",
    "node-fetch": "^3.3.2",
    "uuid": "^10.0.0"
  }
}
