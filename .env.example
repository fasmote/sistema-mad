# Sistema MAD — Configuración
# Copiá este archivo como .env y completá los valores

# ─── OBLIGATORIA ───────────────────────────────────────────────────────────────
# API key de OpenRouter (obtener en openrouter.ai)
OPENROUTER_API_KEY=

# ─── OPCIONALES — Fallback si OpenRouter falla ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ─── CONFIGURACIÓN DEL SISTEMA ─────────────────────────────────────────────────
# Modelo que genera el Briefing
DEFAULT_ORCHESTRATOR_MODEL=anthropic/claude-3-5-sonnet

# Modelo barato para señales de intención (Módulo 2)
DEFAULT_SIGNAL_MODEL=openai/gpt-4o-mini

# Agentes activos por defecto (separados por coma, sin espacios)
DEFAULT_AGENTS=funcional,arquitecto,qa,adversarial

# Rondas máximas por defecto
DEFAULT_MAX_RONDAS=5

# Presupuesto máximo por debate en USD
MAX_DEBATE_COST_USD=5.00

# Carpeta donde se guardan los debates
DEBATES_DIR=./debates

# Nivel de log (debug, info, warn, error)
LOG_LEVEL=info
